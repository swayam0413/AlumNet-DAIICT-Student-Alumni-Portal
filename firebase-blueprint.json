{
  "entities": {
    "user": {
      "title": "User",
      "description": "Represents a student, alumnus, or admin in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "enum": ["student", "alumni", "admin"] },
        "graduation_year": { "type": "integer" },
        "department": { "type": "string" },
        "company": { "type": "string" },
        "job_role": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "profile_image": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "connection": {
      "title": "Connection",
      "description": "Represents a networking connection between two users.",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "status": { "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "receiver_id", "status"]
    },
    "mentorship": {
      "title": "Mentorship",
      "description": "Represents a mentorship relationship between a student and an alumnus.",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "mentor_id": { "type": "string" },
        "status": { "enum": ["pending", "active", "completed", "rejected"] },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["student_id", "mentor_id", "status"]
    },
    "job": {
      "title": "Job",
      "description": "A job or referral opportunity posted by an alumnus.",
      "type": "object",
      "properties": {
        "posted_by": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "company": { "type": "string" },
        "status": { "enum": ["open", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["posted_by", "title", "company"]
    },
    "application": {
      "title": "Application",
      "description": "A student's application to a job post.",
      "type": "object",
      "properties": {
        "job_id": { "type": "string" },
        "student_id": { "type": "string" },
        "resume_url": { "type": "string" },
        "status": { "enum": ["pending", "reviewed", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["job_id", "student_id", "resume_url"]
    },
    "event": {
      "title": "Event",
      "description": "An academic or networking event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Public and private user profiles."
    },
    "/connections/{connectionId}": {
      "schema": "connection",
      "description": "Networking connections."
    },
    "/mentorships/{mentorshipId}": {
      "schema": "mentorship",
      "description": "Mentorship requests and relations."
    },
    "/jobs/{jobId}": {
      "schema": "job",
      "description": "Job portal listings."
    },
    "/applications/{applicationId}": {
      "schema": "application",
      "description": "Job application tracking."
    },
    "/events/{eventId}": {
      "schema": "event",
      "description": "Event management."
    }
  }
}
