rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Hardened Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'password'); }
    function getUserRole(uid) { return get(/databases/$(database)/documents/users/$(uid)).data.role; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'dhruvpanchasara389@gmail.com' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'dhruvpanchasara389@gmail.com') ||
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }

    // 0.2 Connectivity Test Path
    match /test/connection {
      allow read: if isSignedIn();
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'name', 'email', 'role']) && 
               data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['student', 'alumni', 'admin'];
      }

      // Explicitly allow reading one's own identity first to resolve listener errors
      allow get: if isOwner(userId);
      // Allow authenticated users to read and search other non-admin profiles
      allow get: if isSignedIn() && (resource == null || resource.data.role != 'admin' || isAdmin());
      allow list: if isSignedIn() && (resource.data.role == 'alumni' || resource.data.role == 'student' || isAdmin());
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().id == userId &&
                    (incoming().role != 'admin' || isAdmin());
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && 
         incoming().role == existing().role &&
         incoming().isApproved == existing().isApproved && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'graduation_year', 'department', 'company', 'job_role', 'skills', 'profile_image', 'resume_summary', 'resume_parsed_at', 'updatedAt', 'bio', 'id', 'email']))
      );

      allow delete: if isAdmin();
    }

    // 2. Connections Collection
    match /connections/{connectionId} {
      function isValidConnection(data) {
        return data.keys().hasAll(['sender_id', 'receiver_id', 'status']) &&
               isValidId(data.sender_id) && isValidId(data.receiver_id) &&
               data.status in ['pending', 'accepted', 'rejected'];
      }

      allow get: if isSignedIn() && (isOwner(existing().sender_id) || isOwner(existing().receiver_id) || isAdmin());
      allow list: if isSignedIn() && (resource.data.sender_id == request.auth.uid || resource.data.receiver_id == request.auth.uid || isAdmin());

      allow create: if isSignedIn() && isOwner(incoming().sender_id) && isValidConnection(incoming()) &&
                    incoming().status == 'pending' &&
                    exists(/databases/$(database)/documents/users/$(incoming().receiver_id));

      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().receiver_id) && 
         incoming().status in ['accepted', 'rejected'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // 3. Mentorships Collection
    match /mentorships/{mentorshipId} {
      function isValidMentorship(data) {
        return data.keys().hasAll(['student_id', 'mentor_id', 'status']) &&
               data.status in ['pending', 'active', 'completed', 'rejected'];
      }

      allow read: if isSignedIn() && (resource.data.student_id == request.auth.uid || resource.data.mentor_id == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isOwner(incoming().student_id) && isValidId(incoming().mentor_id) &&
                    getUserRole(incoming().mentor_id) == 'alumni';

      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().mentor_id) && 
         incoming().status in ['active', 'completed', 'rejected'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        (isOwner(existing().student_id) && incoming().diff(existing()).affectedKeys().hasOnly(['feedback']))
      );
    }

    // 4. Jobs Collection
    match /jobs/{jobId} {
      function isValidJob(data) {
        return data.keys().hasAll(['posted_by', 'title', 'company']) &&
               data.title is string && data.title.size() <= 200;
      }

      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isOwner(incoming().posted_by) && 
                    getUserRole(request.auth.uid) == 'alumni' && isValidJob(incoming());

      allow update: if isSignedIn() && (isAdmin() || isOwner(existing().posted_by)) && 
                    isValidJob(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'location', 'company', 'status']);
      
      allow delete: if isSignedIn() && (isAdmin() || isOwner(existing().posted_by));
    }

    // 5. Applications Collection
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.student_id == request.auth.uid || 
        get(/databases/$(database)/documents/jobs/$(resource.data.job_id)).data.posted_by == request.auth.uid ||
        isAdmin()
      );

      allow create: if isSignedIn() && isOwner(incoming().student_id) && 
                    exists(/databases/$(database)/documents/jobs/$(incoming().job_id));

      allow update: if isSignedIn() && (
        isAdmin() ||
        (get(/databases/$(database)/documents/jobs/$(existing().job_id)).data.posted_by == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // 6. Events Collection
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
